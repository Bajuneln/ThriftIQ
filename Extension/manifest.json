{
  "manifest_version": 3,
  "name": "eBay AI Analyzer",
  "version": "1.0",
  "description": "Send eBay listing data to AI analyzer",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://www.ebay.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/*"],
      "js": ["content.js"]
    }
  ]
}